# ─── Plausible Analytics ───────────────────────────────────────────────────────
# Sign up at https://plausible.io, add your site, then generate a Stats API key.

# Public domain registered in Plausible (enables the tracking script)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=autourducacao.com

# Server-side credentials for the Stats API (never exposed to the client)
PLAUSIBLE_API_KEY=your-plausible-api-key
PLAUSIBLE_SITE_ID=autourducacao.com

# ─── Site URL (used by dashboard server component for internal fetch) ──────────
NEXT_PUBLIC_SITE_URL=https://autourducacao.com

# ─── Newsletter ───────────────────────────────────────────────────────────────
# Provider: "buttondown" (default) or "brevo"
# Buttondown: create account at https://buttondown.com → Settings → API Keys
# Brevo: create account at https://www.brevo.com → Settings → API Keys
NEWSLETTER_PROVIDER=buttondown
NEWSLETTER_API_KEY=your-newsletter-api-key

# ─── Anthropic / AI content pipeline ─────────────────────────────────────────
# Required for the AI content generation scripts (scripts/generate-content.ts)
ANTHROPIC_API_KEY=your-anthropic-api-key
